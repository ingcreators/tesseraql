# Java / Maven
target/
*.class
*.log
.mvn/wrapper/maven-wrapper.jar

# IDE
.idea/
*.iml
.vscode/*.log

# OS
.DS_Store
Thumbs.db

# TesseraQL local runtime files (anchored so they do not match the io/tesseraql/coverage
# Java package or similarly named source directories)
/work/
/reports/
/coverage/
/.spool/
/.tesseraql/

# Runtime-generated files inside example app homes (system apps unpacked into work/ on serve,
# the report overlay, the spool) - never committed.
examples/*/work/
examples/*/.tesseraql/
examples/*/.spool/
examples/*/reports/

# Local env / secrets
.env
.env.*
!.env.example
.devcontainer/*.local.env
*.pem
*.key
*.p12
# Public-certificate test fixtures (mTLS auth) — cert-only PEM, never private keys (*.key/*.p12
# stay ignored). Needed on the test classpath, so committed despite the *.pem guard above.
!tesseraql-security/src/test/resources/mtls/*.pem
!tesseraql-camel-runtime/src/test/resources/mtls/*.pem

# Agent auth/state
.codex/
.claude/
