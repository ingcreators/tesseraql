{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tesseraql.io/schema/tesseraql-v1.schema.json",
  "title": "TesseraQL Simple YAML v1",
  "description": "Schema for TesseraQL Simple YAML documents: routes (web/**/<method>.yml), jobs (batch/**/job.yml), queue consumers (consume/**), and declarative views (*.view.yml). additionalProperties stays true so newer keys never break older editors. The route recipe enum is kept in sync with the linter by a build-time test.",
  "type": "object",
  "required": ["version", "id", "kind"],
  "properties": {
    "version": { "const": "tesseraql/v1" },
    "id": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["route", "job", "view"] },
    "recipe": {
      "description": "Route recipes (the linter's KNOWN_ROUTE_RECIPES) plus queue-consume (consume/** documents) and the job recipes batch-tasklet/batch-pipeline.",
      "enum": [
        "query-json",
        "command-json",
        "query-html",
        "page",
        "query-export",
        "file-import",
        "file-export",
        "webhook",
        "queue-consume",
        "batch-tasklet",
        "batch-pipeline"
      ]
    },
    "input": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/inputField" }
    },
    "inputPolicy": { "type": "object", "additionalProperties": true },
    "security": {
      "type": "object",
      "properties": {
        "auth": {
          "description": "bearer | browser | apiKey | mtls | public (deny-by-default: no auth means no access to protected data).",
          "type": "string",
          "enum": ["bearer", "browser", "apiKey", "mtls", "public"]
        },
        "policy": { "type": "string", "description": "A policy id under tesseraql.security.policies." },
        "provider": { "type": "string" },
        "csrf": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "idempotency": { "type": "object", "additionalProperties": true },
    "policy": { "type": "object", "additionalProperties": true },
    "outbox": { "type": "object", "additionalProperties": true },
    "datasource": {
      "type": "string",
      "description": "The named connector under tesseraql.datasources the route's SQL runs on, defaulting to main. The name must be declared (TQL-YAML-1035); a non-main route cannot declare notify:/publish:/outbox: or sequence allocation - they ride the main connector (TQL-YAML-1036)."
    },
    "sql": { "$ref": "#/$defs/sqlBinding" },
    "steps": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/sqlBinding" }
    },
    "queries": {
      "type": "object",
      "description": "Additional named queries executed after sql, each bound into the execution context under its name.",
      "additionalProperties": { "$ref": "#/$defs/sqlBinding" }
    },
    "validate": { "type": "object", "additionalProperties": { "type": "object", "additionalProperties": true } },
    "notify": { "type": "object", "additionalProperties": { "type": "object", "additionalProperties": true } },
    "errors": { "type": "object", "additionalProperties": true },
    "import": { "type": "object", "additionalProperties": true },
    "export": { "type": "object", "additionalProperties": true },
    "webhook": {
      "type": "object",
      "properties": {
        "provider": { "type": "string", "description": "A verifier under tesseraql.connectors.webhooks (an unknown provider fails the build)." }
      },
      "additionalProperties": true
    },
    "publish": {
      "type": "object",
      "properties": {
        "channel": { "type": "string" },
        "topic": { "type": "string" },
        "key": { "type": "string" },
        "payload": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "consume": {
      "type": "object",
      "properties": {
        "channel": { "type": "string" },
        "topic": { "type": "string" },
        "idempotencyKey": { "type": "string" }
      },
      "additionalProperties": true
    },
    "page": {
      "description": "Declarative pagination: the framework appends the dialect clause; authored SQL carries no LIMIT/FETCH.",
      "type": "object",
      "properties": {
        "strategy": { "enum": ["offset", "keyset"] },
        "size": { "type": "integer", "minimum": 1 },
        "maxSize": { "type": "integer", "minimum": 1 },
        "count": { "type": "boolean" },
        "by": { "type": "string", "description": "keyset cursor column" }
      },
      "additionalProperties": true
    },
    "response": {
      "type": "object",
      "properties": {
        "json": {
          "type": "object",
          "properties": {
            "status": { "type": "integer", "minimum": 100, "maximum": 599 },
            "body": {},
            "fields": { "type": "object", "additionalProperties": { "$ref": "#/$defs/fieldPolicy" } },
            "statusWhen": { "$ref": "#/$defs/statusWhen" },
            "nest": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "into": { "type": "string" },
                  "children": { "type": "string" },
                  "as": { "type": "string" },
                  "on": { "type": "object", "additionalProperties": { "type": "string" } }
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        },
        "html": {
          "type": "object",
          "properties": {
            "status": { "type": "integer", "minimum": 100, "maximum": 599 },
            "template": { "type": "string" },
            "view": { "type": "string", "description": "A *.view.yml document (exclusive with template:)." },
            "model": { "type": "object", "additionalProperties": true },
            "headers": { "type": "object", "additionalProperties": true },
            "headersWhen": { "type": "object", "additionalProperties": { "type": "string" } },
            "statusWhen": { "$ref": "#/$defs/statusWhen" }
          },
          "additionalProperties": true
        },
        "stream": {
          "type": "object",
          "properties": {
            "contentType": { "type": "string" },
            "filename": { "type": "string" }
          },
          "additionalProperties": true
        },
        "redirect": {
          "type": "object",
          "required": ["location"],
          "properties": {
            "status": { "type": "integer", "minimum": 300, "maximum": 399 },
            "location": { "type": "string" }
          },
          "additionalProperties": true
        },
        "file": {
          "type": "object",
          "required": ["template"],
          "properties": {
            "status": { "type": "integer" },
            "template": { "type": "string" },
            "contentType": { "type": "string" },
            "filename": { "type": "string" },
            "model": { "type": "object" }
          },
          "additionalProperties": true
        },
        "onError": {
          "type": "object",
          "properties": {
            "retarget": { "type": "string" },
            "reswap": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "view": {
      "description": "Declarative view documents (kind: view): list | form | detail | dashboard.",
      "enum": ["list", "form", "detail", "dashboard"]
    },
    "title": { "type": "string" },
    "search": { "type": "string" },
    "source": { "type": "string" },
    "action": { "type": "string" },
    "columns": { "type": "array" },
    "fields": { "type": "array" },
    "panels": { "type": "array" },
    "children": { "type": "object", "additionalProperties": true },
    "slots": { "type": "object", "additionalProperties": { "type": "string" } },
    "trigger": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true,
  "$defs": {
    "inputField": {
      "type": "object",
      "properties": {
        "type": { "enum": ["string", "integer", "number", "boolean", "date", "array"] },
        "required": { "type": "boolean" },
        "default": {},
        "min": { "type": "number" },
        "max": { "type": "number" },
        "maxLength": { "type": "integer", "minimum": 0 },
        "minLength": { "type": "integer", "minimum": 0 },
        "pattern": { "type": "string", "description": "Anchored regular expression (TQL-YAML-1012 when it does not compile)." },
        "format": { "type": "string", "description": "string: email|uuid|url; date/number: a parse pattern.", "examples": ["email", "uuid", "url", "yyyy/MM/dd", "#,##0.##"] },
        "requiredWhen": { "type": "string", "description": "A core expression over params./path./body. (TQL-YAML-1014)." },
        "enum": { "type": "array", "items": { "type": "string" } },
        "writable": { "type": "boolean" },
        "classification": { "type": "string" },
        "mask": { "type": "string" },
        "items": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "enum": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "sqlBinding": {
      "type": "object",
      "properties": {
        "file": { "type": "string", "description": "A colocated 2-way SQL file (must exist; TQL-SQL-2103)." },
        "contract": { "type": "string" },
        "service": { "type": "string" },
        "mode": { "type": "string", "examples": ["query", "query-one", "update", "query-spool"] },
        "timeoutSeconds": { "type": "integer", "minimum": 0, "description": "Per-binding SQL statement timeout override; 0 disables. Default: tesseraql.sql.timeoutSeconds, else 30s." },
        "datasource": { "type": "string", "description": "The named connector this read binding runs on, overriding the route's connector. A step inside a transactional pipeline cannot pick its own connector (TQL-YAML-1037)." },
        "params": { "type": "object", "additionalProperties": { "type": "string" } },
        "sequence": { "type": "string" },
        "keys": { "type": "array", "items": { "type": "string" } },
        "materialize": {
          "type": "object",
          "properties": {
            "maxRows": { "type": "integer" },
            "onOverflow": { "type": "string" }
          },
          "additionalProperties": true
        },
        "expect": {
          "type": "object",
          "properties": {
            "rows": { "type": "integer" },
            "onMismatch": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "fieldPolicy": {
      "type": "object",
      "properties": {
        "visible": { "type": "boolean" },
        "policy": { "type": "string" },
        "mask": { "type": "string" },
        "classification": { "type": "string" },
        "unmaskWhen": { "type": "string" }
      },
      "additionalProperties": true
    },
    "statusWhen": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["when", "status"],
        "properties": {
          "when": { "type": "string" },
          "status": { "type": "integer", "minimum": 100, "maximum": 599 }
        },
        "additionalProperties": true
      }
    }
  }
}
