# Copy to .devcontainer/devcontainer.local.env if you need local-only secrets.
# Do not commit the copied file. The compose file loads it when present.

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# gh CLI auth (alternative to `gh auth login`): a fine-grained PAT scoped to this
# repository with Contents and Pull requests read/write. gh prefers GH_TOKEN.
# GH_TOKEN=
