      </dependency>
      <dependency>
        <groupId>io.tesseraql</groupId>
        <artifactId>tesseraql-coverage-core</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.tesseraql</groupId>
        <artifactId>tesseraql-operations</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.tesseraql</groupId>
        <artifactId>tesseraql-observability</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.tesseraql</groupId>
        <artifactId>tesseraql-report</artifactId>
        <version>${project.version}</version>
