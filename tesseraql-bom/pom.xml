        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.tesseraql</groupId>
        <artifactId>tesseraql-camel-components</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.tesseraql</groupId>
        <artifactId>tesseraql-camel-runtime</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.tesseraql</groupId>
        <artifactId>tesseraql-camel-spring-runtime</artifactId>
        <version>${project.version}</version>
      </dependency>
      <dependency>
        <groupId>io.tesseraql</groupId>
        <artifactId>tesseraql-security</artifactId>
        <version>${project.version}</version>
